/adv_examples/
/perturbations/
/noise_masks/
*.npy
*.npz

# --- Datasets ---
# Never commit your raw data
data/
datasets/
*.csv
*.jsonl
*.h5

# --- Experiment Tracking & Logs ---
# Tensorboard, WandB, and local logs
runs/
wandb/
*.log
.pstats

